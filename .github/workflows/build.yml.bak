name: Build Firmware

on:
  push:
  pull_request:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.x"

      - name: Install PlatformIO
        run: pip install platformio

      - name: Build E213
        shell: bash
        run: |
          set -o pipefail
          pio run -e heltec-ft8-cat -v 2>&1 | tee build-log.txt

      - name: Collect firmware files
        if: always()
        shell: bash
        run: |
          mkdir -p dist

          cp .pio/build/heltec-ft8-cat/bootloader.bin dist/E213-bootloader.bin
          cp .pio/build/heltec-ft8-cat/partitions.bin dist/E213-partition.bin
          cp .pio/build/heltec-ft8-cat/firmware.bin dist/E213-firmware.bin

          cp build-log.txt dist/build.log

      - name: Upload firmware package
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: firmware-package
          path: dist/*